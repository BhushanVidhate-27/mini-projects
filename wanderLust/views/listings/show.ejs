<%- layout("layouts/boilerplate.ejs") %>

    <div class="row ">
        <div class="col-8 offset-2">

            <h3>
                <%= data.title %>
            </h3>
            <div class="listing-card mt-3">
                <img src="<%= data.image %>" class="card-img-top show-img" alt="<%= data.title %>"
                    style="border-radius: 20px;">
                <div class="card-body">
                    <p>
                    <ul>
                        <p>
                            Owned by <i>
                                <%= data.owner.username %>
                            </i>
                        </p>
                        <p>
                            <%= data.description %>
                        </p>
                        <p>&#8377; <%= data.price.toLocaleString("en-IN") %>
                        </p>
                        <p>
                            <%= data.location %>, <%= data.country %>
                        </p>
                    </ul>
                    </p>

                    <% if (currUser && currUser._id.equals(data.owner._id)) { %>
                        <div class="row mt-3 g-2">
                            <div class="col">
                                <a href="/listings/<%= data._id %>/edit" class="btn btn-dark edit-btn w-100">edit this
                                    listing</a>
                            </div>
                            <div class="col">
                                <form action="/listings/<%= data._id %>?_method=DELETE" method="post">
                                    <button type="submit" class="btn btn-dark edit-btn w-100">Delete this
                                        listing</button>
                                </form>
                            </div>
                            <hr>
                        </div>
                        <% } %>
                            <% if (currUser) { %>
                                <div class="col-8 offset-2">
                                    <h4>Leave a review</h4>
                                    <form action="/listings/<%= data._id %>/reviews" method="post"
                                        class="form-control needs-validation" novalidate>
                                        <div class="rating">
                                            <label for="rating">Rating</label><br>
                                            <fieldset class="starability-slot">

                                                <input type="radio" id="no-rate" class="input-no-rate"
                                                    name="review[rating]" value="1" checked aria-label="No rating." />

                                                <input type="radio" id="rate1" name="review[rating]" value="1" />
                                                <label for="rate1">1 star.</label>

                                                <input type="radio" id="rate2" name="review[rating]" value="2" />
                                                <label for="rate2">2 stars.</label>

                                                <input type="radio" id="rate3" name="review[rating]" value="3" />
                                                <label for="rate3">3 stars.</label>

                                                <input type="radio" id="rate4" name="review[rating]" value="4" />
                                                <label for="rate4">4 stars.</label>

                                                <input type="radio" id="rate5" name="review[rating]" value="5" />
                                                <label for="rate5">5 stars.</label>

                                                <span class="starability-focus-ring"></span>
                                            </fieldset>
                                        </div><br>
                                        <div class="comment">
                                            <label for="comment">comment</label><br>
                                            <textarea id="comment" name="review[comment]" class="form-control"
                                                required></textarea>
                                            <div class="invalid-feedback">express yourself</div>
                                        </div><br>
                                        <button class="btn btn-dark">submit</button>
                                    </form>
                                </div>
                                <% } %>
                </div>
            </div>
        </div>
    </div>
    <% if (reviews) { %>
        <div class="row ms-5">
            <% for(e of reviews) { %>
                <div class="card col-6 mb-3" style="width: 18rem;">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= e.author.username %>
                        </h5>
                        <p class="starability-result" data-rating="<%= e.rating %>">
                            rated <%= e.rating %>
                        </p>
                        <p class="card-text">
                            <%= e.comment %>
                        </p>
                        <form action="/listings/<%= data._id %>/reviews/<%= e._id %>?_method=DELETE" method="post">
                            <button type="submit" class="btn btn-dark ">delete</button>
                        </form>
                    </div>
                </div>
                <% } %>
        </div>
        <% } %>
            </div>