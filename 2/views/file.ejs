<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For individual file</title>
</head>
<body>
<link rel="stylesheet" href="/css/style.css">

<div class="container">
    <div class="card">

        <h1><%= fileName %></h1>

        <% if(data.length === 0){ %>

            <h3>File Empty</h3>

        <% } else { %>

            <pre><%= data %></pre>

        <% } %>

    </div>
</div>
</body>
</html>